{
    "name": "quatrebarbes/larchiclass",
    "description": "Some architecture-related commands for Laravel developers",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jean de Quatrebarbes",
            "email": "jean.de.quatrebarbes@hotmail.fr"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Quatrebarbes\\Larchiclass\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Quatrebarbes\\Larchiclass\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quatrebarbes\\Larchiclass\\LarchiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
